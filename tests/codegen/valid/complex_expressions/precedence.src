// Test: complex expressions with operator precedence (Sprint 6 EXPR-1, EXPR-2)
fn main() -> int {
    int a = 2 + 3 * 4;          // 2 + 12 = 14
    int b = (2 + 3) * 4;        // 5 * 4 = 20
    int c = 100 / 5 - 3 * 2;    // 20 - 6 = 14
    int d = 10 % 3 + 7 % 4;     // 1 + 3 = 4
    int e = -a + b;              // -14 + 20 = 6
    return a + b + c + d + e;    // 14 + 20 + 14 + 4 + 6 = 58
}

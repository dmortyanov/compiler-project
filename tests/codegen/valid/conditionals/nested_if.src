// Test: nested if-else (Sprint 6 COND-4)
fn classify(int x) -> int {
    if (x > 0) {
        if (x > 100) {
            return 3;
        } else {
            return 2;
        }
    } else {
        if (x < -100) {
            return -3;
        } else {
            return -2;
        }
    }
}

fn main() -> int {
    int a = classify(50);
    int b = classify(-200);
    return a - b;
}

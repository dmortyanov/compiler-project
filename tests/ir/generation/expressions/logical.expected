function main: int ()
  entry:
    t0 = MOVE 10    # int a
    t1 = MOVE 20    # int b
    t2 = CMP_LT t0, t1
    t3 = MOVE t2    # bool c
    JUMP_IF t3, L_and_rhs_0
    JUMP L_and_end_1

  L_and_rhs_0:
    JUMP L_and_end_1

  L_and_end_1:
    t4 = PHI (false, entry), (true, L_and_rhs_0)
    t5 = MOVE t4    # bool d
    RETURN 0


function factorial: int (int n)
  entry:
    t0 = MOVE [n]
    t1 = CMP_LE t0, 1
    JUMP_IF t1, L_then_0
    JUMP L_endif_1

  L_then_0:
    RETURN 1

  L_endif_1:
    t2 = SUB t0, 1
    PARAM 0, t2
    t3 = CALL factorial, 1
    t4 = MUL t0, t3
    RETURN t4

function main: int ()
  entry:
    PARAM 0, 5
    t0 = CALL factorial, 1
    t1 = MOVE t0    # int result
    RETURN t1


function main: int ()
  entry:
    t0 = MOVE 0    # int sum
    t1 = MOVE 1    # int i
    JUMP L_for_0

  L_for_0:
    t2 = PHI (t1, entry), (t8, L_forupd_2)
    t3 = PHI (t0, entry), (t6, L_forupd_2)
    t4 = CMP_LE t2, 5
    JUMP_IF t4, L_forbody_1
    JUMP L_endfor_3

  L_forbody_1:
    t5 = ADD t3, t2
    t6 = MOVE t5
    JUMP L_forupd_2

  L_forupd_2:
    t7 = ADD t2, 1
    t8 = MOVE t7
    JUMP L_for_0

  L_endfor_3:
    RETURN t6


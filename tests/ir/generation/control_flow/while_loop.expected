function main: int ()
  entry:
    t0 = MOVE 0    # int i
    JUMP L_while_0

  L_while_0:
    t1 = PHI (t0, entry), (t4, L_body_1)
    t2 = CMP_LT t1, 10
    JUMP_IF t2, L_body_1
    JUMP L_endwhile_2

  L_body_1:
    t3 = ADD t1, 1
    t4 = MOVE t3
    JUMP L_while_0

  L_endwhile_2:
    RETURN t4

